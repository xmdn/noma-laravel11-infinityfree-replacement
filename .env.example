APP_NAME=NOMA
APP_ENV=local
APP_KEY=base64:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
APP_DEBUG=true
APP_URL=http://localhost:8083
TRUSTED_PROXIES=*

# Optional initial administrator created by `php artisan db:seed`.
NOMA_ADMIN_NAME="NOMA Administrator"
NOMA_ADMIN_EMAIL=
NOMA_ADMIN_PASSWORD=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=noma
DB_USERNAME=noma
DB_PASSWORD=local-dev-password

LANDLORD_DB_HOST=postgres
LANDLORD_DB_PORT=5432
LANDLORD_DB_DATABASE=noma_landlord
LANDLORD_DB_USERNAME=noma
LANDLORD_DB_PASSWORD=local-dev-password

TENANT_DB_HOST=postgres
TENANT_DB_PORT=5432
TENANT_DB_USERNAME=noma
TENANT_DB_PASSWORD=local-dev-password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

NOMA_CART_TTL_MINUTES=2
NOMA_CUSTOMER_ACCESS_TTL_MINUTES=3
NOMA_AUTO_VERIFY_EMAILS=true
NOMA_SHOP_URL_MODE=auto

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=rabbitmq

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=noma
RABBITMQ_PASSWORD=local-dev-password
RABBITMQ_VHOST=/
RABBITMQ_QUEUE=emails
RABBITMQ_WORKER=default

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Docker / Codespaces local stack port mappings.
NOMA_BIND_IP=127.0.0.1
NOMA_APP_PORT=8083
NOMA_POSTGRES_PORT=5432
NOMA_RABBITMQ_PORT=5672
NOMA_RABBITMQ_MANAGEMENT_PORT=15672
NOMA_MAILPIT_SMTP_PORT=1025
NOMA_MAILPIT_UI_PORT=8025
NOMA_PGADMIN_PORT=5050
NOMA_HTTP_PORT=80
NOMA_HTTPS_PORT=443

# Public nginx / Let's Encrypt endpoints.
EMIT_DOMAIN=emitapi.us.to
EMIT_APP_HOST=emitapi.us.to
EMIT_RABBITMQ_HOST=rabbitmq.emitapi.us.to
EMIT_MAILPIT_HOST=mailpit.emitapi.us.to
EMIT_DB_HOST=db.emitapi.us.to
CERTBOT_EMAIL=admin@emitapi.us.to

# Basic auth in front of RabbitMQ, Mailpit, and pgAdmin through nginx.
NOMA_PROXY_BASIC_AUTH_USER=noma-admin
NOMA_PROXY_BASIC_AUTH_PASSWORD=change-this-admin-proxy-password

# PostgreSQL web administration through pgAdmin.
PGADMIN_DEFAULT_EMAIL=admin@emitapi.us.to
PGADMIN_DEFAULT_PASSWORD=change-this-pgadmin-password
